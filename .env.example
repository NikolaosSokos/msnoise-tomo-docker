# Copy this file to ".env" and adjust as needed:   cp .env.example .env

# ---- Database backend ----
# sqlite = zero-config, stored in ./project (recommended to start with)
# mysql  = use the MariaDB container (also add --profile mysql when launching)
DB_TECH=sqlite

# ---- MySQL / MariaDB settings (only used when DB_TECH=mysql) ----
MYSQL_HOST=mariadb
MYSQL_DB=msnoise
MYSQL_USER=msnoise
MYSQL_PASSWORD=msnoise
MYSQL_ROOT_PASSWORD=change-me-root

# ---- Ports (host side) ----
WEB_PORT=5000
JUPYTER_PORT=8888

# ---- JupyterLab access token ----
JUPYTER_TOKEN=msnoise
